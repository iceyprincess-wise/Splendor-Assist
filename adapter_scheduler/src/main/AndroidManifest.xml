<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.assistant.adapter.scheduler">

    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <application
        android:allowBackup="false"
        android:icon="@drawable/ic_extension"
        android:label="Splendor Scheduler Adapter"
        android:hardwareAccelerated="true">
        
        <service
            android:name=".SchedulerAdapterService"
            android:exported="true"
            android:process=":kernel_scheduler"
            android:foregroundServiceType="specialUse">
            <property android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                      android:value="Coordinates adapter scheduling and fleet orchestration telemetry."/>
        </service>
    </application>
</manifest>
