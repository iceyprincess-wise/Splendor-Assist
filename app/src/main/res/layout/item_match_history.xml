<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#151515"
    android:layout_marginBottom="4dp"
    android:padding="12dp">

    <TextView
        android:id="@+id/tv_match_id"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#E0E0E0"
        android:textStyle="bold"
        android:textSize="14sp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tv_match_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="12sp"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/tv_match_id"
        app:layout_constraintStart_toStartOf="parent" />

    <LinearLayout
    android:tag="PHASE10_MATERIAL3_LAYOUT_MARKER"
        android:id="@+id/ll_tactical_stats"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="3"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/tv_match_status">

        <TextView
            android:id="@+id/tv_possession"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#90CAF9"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tv_long_pass"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#A5D6A7"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tv_interceptions"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#FFAB91"
            android:textSize="12sp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
