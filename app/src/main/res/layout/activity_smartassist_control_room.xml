<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D47A1">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SMART ASSIST CONTROL ROOM"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="22sp"/>

        <Switch
            android:id="@+id/swEnabled"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ENABLE SMART ASSIST"
            android:textColor="#FFFFFF"
            android:layout_marginTop="20dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PASS ASSIST"
            android:textColor="#FFFFFF"/>

        <SeekBar
            android:id="@+id/passSeek"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SHOT ASSIST"
            android:textColor="#FFFFFF"/>

        <SeekBar
            android:id="@+id/shotSeek"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CROSS ASSIST"
            android:textColor="#FFFFFF"/>

        <SeekBar
            android:id="@+id/crossSeek"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"/>

        <Switch
            android:id="@+id/swPanic"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ENABLE PANIC ASSIST"
            android:textColor="#FFFFFF"
            android:layout_marginTop="20dp"/>

        <TextView
            android:id="@+id/tvRuntime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:layout_marginTop="20dp"/>

        <TextView
            android:id="@+id/tvMetrics"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#00FFAA"
            android:layout_marginTop="10dp"/>

        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="SAVE"
            android:layout_marginTop="20dp"/>

    </LinearLayout>

</ScrollView>
