<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A">

    <androidx.media3.ui.PlayerView
        android:id="@+id/dvr_player_view"
        android:layout_width="0dp"
        android:layout_height="250dp"
        android:keepScreenOn="true"
        app:use_controller="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
    android:tag="PHASE10_MATERIAL3_LAYOUT_MARKER"
        android:id="@+id/action_command_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#1C1C1C"
        android:padding="8dp"
        app:layout_constraintTop_toBottomOf="@id/dvr_player_view">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_save_rom"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="SAVE TO 128GB ROM"
            android:textColor="#FFFFFF"
            android:backgroundTint="#2E7D32"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tv_ttl_countdown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:paddingStart="12dp"
            android:text="TTL: 48h 00m"
            android:textColor="#FF5252"
            android:textStyle="bold" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_match_history"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/action_command_bar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
