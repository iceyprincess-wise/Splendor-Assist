<?xml version="1.0" encoding="utf-8"?>

<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#10131A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SPLENDOR ASSIST"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"/>

        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Runtime Control Center"
            android:textColor="#A0A0A0"
            android:layout_marginBottom="24dp"/>

        <Button
            android:id="@+id/btnStartEngine"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="START ENGINE"/>

        <Button
            android:id="@+id/btnViewLogs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="VIEW LOGS"/>

        <TextView
            android:id="@+id/tvRuntimeSummary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Runtime Summary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginTop="24dp"/>

        <TextView
            android:id="@+id/tvInputAdapter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"/>

        <TextView
            android:id="@+id/tvLmkAdapter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"/>

        <TextView
            android:id="@+id/tvNetAdapter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"/>

        <TextView
            android:id="@+id/tvSyncAdapter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"/>

        <TextView
            android:id="@+id/tvAdapterCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#00FFAA"
            android:layout_marginTop="16dp"/>

    </LinearLayout>

</ScrollView>
