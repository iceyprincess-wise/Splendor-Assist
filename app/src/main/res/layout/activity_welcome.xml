<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:tag="PHASE10_MATERIAL3_LAYOUT_MARKER" xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A"
    android:gravity="center"
    android:orientation="vertical">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SPLENDOR ASSIST"
        android:textColor="#00FF00"
        android:textSize="28sp"
        android:textStyle="bold"
        android:letterSpacing="0.1" />

    <TextView
        android:id="@+id/tvCheckState"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="[*] INITIALIZING DYNAMIC SECURE STATE..."
        android:textColor="#80FF80"
        android:textSize="14sp"
        android:fontFamily="monospace" />

    <ProgressBar
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:layout_marginTop="30dp"
        android:indeterminateTint="#00FF00" />
</LinearLayout>
